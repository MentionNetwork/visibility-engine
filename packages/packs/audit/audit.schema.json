{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mention.network/schemas/audit-0.1.0.json",
  "title": "Mention Network Audit Pack",
  "description": "A rubric of on-store/off-store/offer criteria scored 0/50/100 × weight. Apache-2.0.",
  "type": "object",
  "required": ["id", "type", "area", "version", "engineApi", "label", "criteria"],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
    "type": { "const": "audit" },
    "area": { "enum": ["on_store", "off_store", "offer"] },
    "version": { "type": "string" },
    "engineApi": { "type": "string" },
    "label": { "$ref": "#/$defs/localized" },
    "criteria": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/criterion" } }
  },
  "$defs": {
    "localized": {
      "type": "object", "required": ["en"],
      "properties": { "en": { "type": "string" } },
      "additionalProperties": { "type": "string" }
    },
    "criterion": {
      "type": "object",
      "required": ["id", "label", "group", "area", "weight", "scope", "check", "scoring"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9._-]*$" },
        "label": { "$ref": "#/$defs/localized" },
        "group": { "type": "string" },
        "area": { "enum": ["on_store", "off_store", "offer"] },
        "weight": { "enum": ["critical", "high", "medium"] },
        "scope": { "enum": ["store", "product_page"] },
        "check": { "type": "string" },
        "params": { "type": "object", "additionalProperties": { "type": "string" } },
        "scoring": {
          "type": "object", "required": ["0", "50", "100"],
          "properties": { "0": { "type": "string" }, "50": { "type": "string" }, "100": { "type": "string" } }
        }
      }
    }
  }
}
